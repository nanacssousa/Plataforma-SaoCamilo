{
  "expo": {
    "name": "H2O Elite",
    "slug": "h2o-elite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "h2oelite",
    "splash": {
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8"
      },
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para definir sua foto de perfil.",
          "cameraPermission": "Permitir acesso à câmera para tirar sua foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#8f000a"
        }
      ],
      "expo-font"
    ]
  }
}
